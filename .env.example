# Copy this file to `.env.local` and fill in your real Supabase values.
# `.env.local` is gitignored — never commit real keys.

# From Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, full access. Never expose to the browser.
# Used by API routes for uploads, inserts, and signed download URLs.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Name of the private Storage bucket that holds the invoice PDFs
SUPABASE_INVOICES_BUCKET=invoices
